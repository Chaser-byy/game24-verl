# Target verl version: v0.7.1
# Install verl, Ray, PyTorch, vLLM, CUDA, and model access separately on the GPU server.

MODEL_PATH=Qwen/Qwen2.5-1.5B-Instruct
TRAIN_FILE=data/game24/train.parquet
VAL_FILE=data/game24/val.parquet
REWARD_FILE=game24/reward.py
OUTPUT_DIR=outputs/game24-grpo-lora
PROJECT_NAME=game24-verl
EXPERIMENT_NAME=qwen25-1p5b-grpo-lora

TRAIN_BATCH_SIZE=32
ROLLOUT_N=8
MAX_PROMPT_LENGTH=192
MAX_RESPONSE_LENGTH=256
LORA_RANK=64
LORA_ALPHA=64
LEARNING_RATE=2e-6
TOTAL_EPOCHS=8
TOTAL_TRAINING_STEPS=
SAVE_FREQ=50
TEST_FREQ=25
GPU_MEMORY_UTILIZATION=0.45
N_GPUS=1
DTYPE=bfloat16

# Optional logging configuration consumed by your server environment.
WANDB_PROJECT=game24-verl
WANDB_MODE=online
