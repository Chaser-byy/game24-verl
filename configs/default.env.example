# Target verl version: v0.7.1
# Install verl, Ray, PyTorch, vLLM, CUDA, and model access separately on the GPU server.
# The scripts also accept the unprefixed names shown in their headers; prefixes avoid collisions when sourcing this file.

# Shared
PROJECT_NAME=game24-verl
N_GPUS=1
DTYPE=bfloat16
WANDB_PROJECT=game24-verl
WANDB_MODE=online

# Data
PROCESSED_DATA_DIR=data/game24
SFT_DATA_DIR=data/game24-sft

# Full-parameter SFT warm start
SFT_MODEL_PATH=Qwen/Qwen2.5-1.5B-Instruct
SFT_TRAIN_FILE=data/game24-sft/sft_train.parquet
SFT_VAL_FILE=data/game24-sft/sft_val.parquet
SFT_OUTPUT_DIR=outputs/game24-sft-full
SFT_EXPERIMENT_NAME=qwen25-1p5b-sft-full
SFT_TRAIN_BATCH_SIZE=32
SFT_MICRO_BATCH_SIZE=4
SFT_MAX_LENGTH=512
SFT_MAX_TOKEN_LEN_PER_GPU=8192
SFT_LEARNING_RATE=5e-6
SFT_TOTAL_EPOCHS=1
SFT_TOTAL_TRAINING_STEPS=
SFT_SAVE_FREQ=-1
SFT_TEST_FREQ=-1
SFT_CHECKPOINT_SAVE_CONTENTS=["model","optimizer","extra","hf_model"]
# Empty SFT_ATTENTION_IMPLEMENTATION means do not emit the model.override_config attention override.
# The default sdpa avoids requiring flash_attn in smoke/default runs.
SFT_ATTENTION_IMPLEMENTATION=sdpa
SFT_USE_REMOVE_PADDING=False

# GRPO-LoRA after SFT.
# Set GRPO_MODEL_PATH or MODEL_PATH to the exported Hugging Face SFT model directory.
GRPO_MODEL_PATH=/path/to/exported-sft-hf-model
GRPO_TRAIN_FILE=data/game24/train.parquet
GRPO_VAL_FILE=data/game24/val.parquet
GRPO_REWARD_FILE=game24/reward.py
GRPO_OUTPUT_DIR=outputs/game24-grpo-smoke
GRPO_PROJECT_NAME=game24-grpo
GRPO_EXPERIMENT_NAME=game24-grpo-smoke
GRPO_LOGGER=console
GRPO_TRAIN_BATCH_SIZE=4
GRPO_ROLLOUT_N=4
GRPO_PPO_MINI_BATCH_SIZE=4
GRPO_PPO_MICRO_BATCH_SIZE_PER_GPU=1
GRPO_LOG_PROB_MICRO_BATCH_SIZE_PER_GPU=1
GRPO_REF_LOG_PROB_MICRO_BATCH_SIZE_PER_GPU=1
GRPO_MAX_PROMPT_LENGTH=192
GRPO_MAX_RESPONSE_LENGTH=256
GRPO_LORA_RANK=64
GRPO_LORA_ALPHA=64
GRPO_LEARNING_RATE=1e-6
GRPO_TOTAL_EPOCHS=8
GRPO_TOTAL_TRAINING_STEPS=5
GRPO_TEMPERATURE=1.0
GRPO_TOP_P=0.95
GRPO_ATTN_IMPLEMENTATION=sdpa
GRPO_USE_REMOVE_PADDING=false
GRPO_SAVE_FREQ=50
GRPO_TEST_FREQ=25
GRPO_GPU_MEMORY_UTILIZATION=0.45

# Full-parameter GRPO after SFT.
# This is a separate formal training path from GRPO-LoRA.
FULL_GRPO_MODEL_PATH=/root/autodl-tmp/outputs/game24-sft-full/global_step_363/huggingface
FULL_GRPO_TRAIN_FILE=data/game24/train.parquet
FULL_GRPO_VAL_FILE=data/game24/val.parquet
FULL_GRPO_REWARD_FILE=game24/reward.py
# If unset, the script uses /root/autodl-tmp/outputs/game24-grpo-full-param-<timestamp>.
FULL_GRPO_OUTPUT_DIR=
FULL_GRPO_PROJECT_NAME=game24-grpo-full-param
FULL_GRPO_EXPERIMENT_NAME=game24-grpo-full-param
FULL_GRPO_LOGGER=console
FULL_GRPO_LOG_FILE=
FULL_GRPO_TRAIN_BATCH_SIZE=8
FULL_GRPO_ROLLOUT_N=8
FULL_GRPO_MAX_PROMPT_LENGTH=192
FULL_GRPO_MAX_RESPONSE_LENGTH=192
FULL_GRPO_PPO_MINI_BATCH_SIZE=8
FULL_GRPO_PPO_EPOCHS=1
FULL_GRPO_PPO_MICRO_BATCH_SIZE_PER_GPU=4
FULL_GRPO_LOG_PROB_MICRO_BATCH_SIZE_PER_GPU=16
FULL_GRPO_REF_LOG_PROB_MICRO_BATCH_SIZE_PER_GPU=16
FULL_GRPO_LEARNING_RATE=3e-7
FULL_GRPO_TOTAL_TRAINING_STEPS=400
FULL_GRPO_SAVE_FREQ=25
FULL_GRPO_VAL_FREQ=25
FULL_GRPO_VAL_BEFORE_TRAIN=true
FULL_GRPO_MAX_ACTOR_CKPT_TO_KEEP=1
FULL_GRPO_GPU_MEMORY_UTILIZATION=0.35
FULL_GRPO_N_GPUS=1
FULL_GRPO_DTYPE=bfloat16
FULL_GRPO_TEMPERATURE=1.0
FULL_GRPO_TOP_P=0.95
FULL_GRPO_ATTN_IMPLEMENTATION=sdpa
FULL_GRPO_USE_REMOVE_PADDING=false
FULL_GRPO_ENABLE_GRADIENT_CHECKPOINTING=true
FULL_GRPO_USE_KL_LOSS=true
FULL_GRPO_KL_LOSS_COEF=0.001
FULL_GRPO_KL_LOSS_TYPE=low_var_kl
FULL_GRPO_CHECKPOINT_SAVE_CONTENTS='["model","optimizer","extra","hf_model"]'
FULL_GRPO_RESUME_MODE=disable
FULL_GRPO_RESUME_FROM_PATH=

# Improved LoRA GRPO after SFT.
# This is isolated from the original GRPO-LoRA baseline and starts fresh from SFT.
IMPROVED_GRPO_MODEL_PATH=/path/to/exported-sft-hf-model
IMPROVED_GRPO_TRAIN_FILE=data/game24/train.parquet
IMPROVED_GRPO_VAL_FILE=data/game24/val.parquet
IMPROVED_GRPO_TEST_FILE=data/game24/test.parquet
IMPROVED_GRPO_HARD100_FILE=data/game24/tot_hard100.parquet
IMPROVED_GRPO_SFT_TRAIN_FILE=data/game24-sft/sft_train.parquet
IMPROVED_GRPO_REWARD_FILE=game24/reward_strict.py
IMPROVED_GRPO_REWARD_MANAGER_FILE=game24/strict_dapo_reward_manager.py
IMPROVED_GRPO_OUTPUT_DIR=outputs/game24-grpo-lora-improved
IMPROVED_GRPO_PROJECT_NAME=game24-grpo-lora-improved
IMPROVED_GRPO_EXPERIMENT_NAME=game24-grpo-lora-improved
IMPROVED_GRPO_LOGGER=console
IMPROVED_GRPO_TRAIN_BATCH_SIZE=8
IMPROVED_GRPO_GEN_BATCH_SIZE=24
IMPROVED_GRPO_MAX_GEN_BATCHES=4
IMPROVED_GRPO_ROLLOUT_N=16
IMPROVED_GRPO_MAX_PROMPT_LENGTH=192
IMPROVED_GRPO_MAX_RESPONSE_LENGTH=192
IMPROVED_GRPO_LORA_RANK=64
IMPROVED_GRPO_LORA_ALPHA=64
IMPROVED_GRPO_TARGET_MODULES=all-linear
IMPROVED_GRPO_LORA_DROPOUT=0
IMPROVED_GRPO_PPO_MINI_BATCH_SIZE=4
IMPROVED_GRPO_PPO_EPOCHS=2
IMPROVED_GRPO_PPO_MICRO_BATCH_SIZE_PER_GPU=32
IMPROVED_GRPO_LOG_PROB_MICRO_BATCH_SIZE_PER_GPU=64
IMPROVED_GRPO_REF_LOG_PROB_MICRO_BATCH_SIZE_PER_GPU=64
IMPROVED_GRPO_LEARNING_RATE=5e-6
IMPROVED_GRPO_GRAD_CLIP=1.0
IMPROVED_GRPO_TEMPERATURE=1.0
IMPROVED_GRPO_TOP_P=1.0
IMPROVED_GRPO_TOP_K=-1
IMPROVED_GRPO_USE_KL_LOSS=false
IMPROVED_GRPO_KL_LOSS_COEF=0
IMPROVED_GRPO_CLIP_RATIO_LOW=0.20
IMPROVED_GRPO_CLIP_RATIO_HIGH=0.28
IMPROVED_GRPO_CLIP_RATIO_C=10.0
IMPROVED_GRPO_LOSS_AGG_MODE=seq-mean-token-mean
IMPROVED_GRPO_ATTN_IMPLEMENTATION=sdpa
IMPROVED_GRPO_USE_REMOVE_PADDING=false
IMPROVED_GRPO_ENABLE_GRADIENT_CHECKPOINTING=false
IMPROVED_GRPO_GPU_MEMORY_UTILIZATION=0.45
IMPROVED_GRPO_N_GPUS=1
IMPROVED_GRPO_DTYPE=bfloat16
IMPROVED_GRPO_TOTAL_TRAINING_STEPS=200
IMPROVED_GRPO_SAVE_FREQ=20
IMPROVED_GRPO_TEST_FREQ=10
IMPROVED_GRPO_VAL_BEFORE_TRAIN=true

# Strict final evaluation.
# SFT_MODEL_PATH should point to the exported Hugging Face SFT directory.
# GRPO_RUN_DIR should point to one training output directory containing global_step_xxx/actor/lora_adapter.
RAW_MODEL_PATH=Qwen/Qwen2.5-1.5B-Instruct
SFT_MODEL_PATH=/path/to/exported-sft-hf-model
GRPO_RUN_DIR=/path/to/grpo-run-dir
EVAL_DATA_DIR=data/game24
EVAL_OUTPUT_DIR=outputs/evaluation
EVAL_MODE=quick
EVAL_MAX_NEW_TOKENS=192
EVAL_BATCH_SIZE=32
EVAL_SEED=2026
EVAL_SAMPLE_N=8
EVAL_SAMPLE_TEMPERATURE=0.7
EVAL_SAMPLE_TOP_P=0.95
EVAL_TORCH_DTYPE=bfloat16
EVAL_DIAGNOSTIC_LIMIT=20

# Strict single-model evaluation.
# Set SINGLE_EVAL_PASS_N=16 to run batched sampling Pass@16 from run_single_model_evaluation.sh.
SINGLE_EVAL_CONFIG=configs/evaluation/single_model/default.yaml
SINGLE_EVAL_DATA_SPLIT=all
SINGLE_EVAL_BATCH_SIZE=32
SINGLE_EVAL_MAX_NEW_TOKENS=192
SINGLE_EVAL_SEED=2026
SINGLE_EVAL_PASS_N=1
SINGLE_EVAL_DO_SAMPLE=
SINGLE_EVAL_TEMPERATURE=0.7
SINGLE_EVAL_TOP_P=0.95
SINGLE_EVAL_TOP_K=
SINGLE_EVAL_OUTPUT_DIR=
SINGLE_EVAL_OVERWRITE=false
